<section class="hero" id="hero">
  <div class="hero-sigil-wrap">
    <svg class="hero-sigil" viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
      <!-- Outer circle -->
      <circle cx="200" cy="200" r="185" class="sigil-line sigil-draw" style="--dash-length: 1163; --delay: 0s;" />
      <!-- Middle circle -->
      <circle cx="200" cy="200" r="135" class="sigil-line sigil-draw" style="--dash-length: 848; --delay: 0.3s;" />
      <!-- Inner circle -->
      <circle cx="200" cy="200" r="75" class="sigil-line sigil-draw" style="--dash-length: 471; --delay: 0.6s;" />

      <!-- Cardinal lines (through full diameter) -->
      <line x1="200" y1="15" x2="200" y2="385" class="sigil-line sigil-draw" style="--dash-length: 370; --delay: 0.8s;" />
      <line x1="15" y1="200" x2="385" y2="200" class="sigil-line sigil-draw" style="--dash-length: 370; --delay: 0.9s;" />

      <!-- Diagonal lines -->
      <line x1="69" y1="69" x2="331" y2="331" class="sigil-line sigil-draw thin" style="--dash-length: 370; --delay: 1.0s;" />
      <line x1="331" y1="69" x2="69" y2="331" class="sigil-line sigil-draw thin" style="--dash-length: 370; --delay: 1.1s;" />

      <!-- Decorative arcs between middle and outer circle -->
      <path d="M 200 65 A 135 135 0 0 1 335 200" class="sigil-line sigil-draw thin" style="--dash-length: 212; --delay: 1.2s;" fill="none" />
      <path d="M 335 200 A 135 135 0 0 1 200 335" class="sigil-line sigil-draw thin" style="--dash-length: 212; --delay: 1.3s;" fill="none" />
      <path d="M 200 335 A 135 135 0 0 1 65 200" class="sigil-line sigil-draw thin" style="--dash-length: 212; --delay: 1.4s;" fill="none" />
      <path d="M 65 200 A 135 135 0 0 1 200 65" class="sigil-line sigil-draw thin" style="--dash-length: 212; --delay: 1.5s;" fill="none" />

      <!-- Small circles at 8 compass points on outer ring -->
      <circle cx="200" cy="15" r="4" class="sigil-dot" style="--delay: 1.6s;" />
      <circle cx="331" cy="69" r="4" class="sigil-dot" style="--delay: 1.65s;" />
      <circle cx="385" cy="200" r="4" class="sigil-dot" style="--delay: 1.7s;" />
      <circle cx="331" cy="331" r="4" class="sigil-dot" style="--delay: 1.75s;" />
      <circle cx="200" cy="385" r="4" class="sigil-dot" style="--delay: 1.8s;" />
      <circle cx="69" cy="331" r="4" class="sigil-dot" style="--delay: 1.85s;" />
      <circle cx="15" cy="200" r="4" class="sigil-dot" style="--delay: 1.9s;" />
      <circle cx="69" cy="69" r="4" class="sigil-dot" style="--delay: 1.95s;" />

      <!-- 5 small diamonds on middle circle (one per tool) -->
      <rect x="196" y="61" width="8" height="8" transform="rotate(45 200 65)" class="sigil-diamond" style="--delay: 2.0s; --color: var(--seer);" />
      <rect x="323" y="146" width="8" height="8" transform="rotate(45 327 150)" class="sigil-diamond" style="--delay: 2.1s; --color: var(--tome);" />
      <rect x="304" y="306" width="8" height="8" transform="rotate(45 308 310)" class="sigil-diamond" style="--delay: 2.2s; --color: var(--tower);" />
      <rect x="88" y="306" width="8" height="8" transform="rotate(45 92 310)" class="sigil-diamond" style="--delay: 2.3s; --color: var(--scrolls);" />
      <rect x="69" y="146" width="8" height="8" transform="rotate(45 73 150)" class="sigil-diamond" style="--delay: 2.4s; --color: var(--familiar);" />

      <!-- Central ornament -->
      <circle cx="200" cy="200" r="12" class="sigil-center" style="--delay: 2.5s;" />
      <circle cx="200" cy="200" r="4" class="sigil-center-dot" style="--delay: 2.6s;" />
    </svg>
  </div>

  <div class="hero-content">
    <h1 class="hero-title">Arcanum</h1>
    <div class="hero-divider">
      <span class="hero-divider-line"></span>
      <span class="hero-divider-diamond"></span>
      <span class="hero-divider-line"></span>
    </div>
    <p class="hero-tagline">The Complete Domain Intelligence Suite</p>
    <p class="hero-description">
      Five tools unified under a single install — diagnostics, reference data,
      AI integration, agent skills, and conversational intelligence for the domain name industry.
    </p>
    <a href="#projects" class="hero-cta">Explore the Suite</a>
  </div>

  <div class="hero-scroll-indicator">
    <div class="hero-scroll-line"></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 4rem 2rem;
    overflow: hidden;
  }

  /* --- Sigil --- */
  .hero-sigil-wrap {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 0;
  }

  .hero-sigil {
    width: min(70vw, 560px);
    height: min(70vw, 560px);
    opacity: 0.12;
    animation: rotateSlowly 180s linear infinite;
  }

  .sigil-line {
    fill: none;
    stroke: var(--gold);
    stroke-width: 1;
    stroke-dasharray: var(--dash-length);
    stroke-dashoffset: var(--dash-length);
    animation: drawStroke 2s var(--ease-out-expo) forwards;
    animation-delay: var(--delay);
  }

  .sigil-line.thin {
    stroke-width: 0.5;
    opacity: 0.6;
  }

  .sigil-dot {
    fill: var(--gold);
    opacity: 0;
    animation: fadeIn 0.5s ease forwards;
    animation-delay: var(--delay);
  }

  .sigil-diamond {
    fill: var(--color, var(--gold));
    opacity: 0;
    animation: fadeIn 0.5s ease forwards;
    animation-delay: var(--delay);
  }

  .sigil-center {
    fill: none;
    stroke: var(--gold);
    stroke-width: 1.5;
    opacity: 0;
    animation: fadeIn 0.6s ease forwards;
    animation-delay: var(--delay);
  }

  .sigil-center-dot {
    fill: var(--gold);
    opacity: 0;
    animation: fadeIn 0.4s ease forwards;
    animation-delay: var(--delay);
  }

  /* --- Content --- */
  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 640px;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 10vw, 6rem);
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    text-shadow:
      0 0 60px rgba(201, 168, 76, 0.4),
      0 0 120px rgba(201, 168, 76, 0.15),
      0 2px 4px rgba(0, 0, 0, 0.5);
    opacity: 0;
    animation: heroTitleIn 1.2s var(--ease-out-expo) 0.5s forwards;
  }

  @keyframes heroTitleIn {
    from {
      opacity: 0;
      transform: translateY(20px) scale(0.97);
      letter-spacing: 0.35em;
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
      letter-spacing: 0.2em;
    }
  }

  /* --- Divider --- */
  .hero-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin: 1.5rem 0;
    opacity: 0;
    animation: fadeIn 0.8s ease 1.4s forwards;
  }

  .hero-divider-line {
    display: block;
    width: 60px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold));
  }

  .hero-divider-line:last-child {
    background: linear-gradient(90deg, var(--gold), transparent);
  }

  .hero-divider-diamond {
    width: 6px;
    height: 6px;
    background: var(--gold);
    transform: rotate(45deg);
    flex-shrink: 0;
  }

  /* --- Tagline --- */
  .hero-tagline {
    font-family: var(--font-heading);
    font-size: clamp(1.1rem, 2.5vw, 1.4rem);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-bright);
    opacity: 0;
    animation: fadeIn 0.8s ease 1.6s forwards;
  }

  .hero-description {
    margin-top: 1.5rem;
    font-size: 1.15rem;
    line-height: 1.8;
    color: var(--text-dim);
    max-width: 520px;
    margin-left: auto;
    margin-right: auto;
    opacity: 0;
    animation: fadeIn 0.8s ease 1.9s forwards;
  }

  .hero-cta {
    display: inline-block;
    margin-top: 2.5rem;
    padding: 0.75rem 2.5rem;
    font-family: var(--font-heading);
    font-size: 0.85rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    border: 1px solid var(--gold-dim);
    border-radius: 2px;
    transition: all 0.4s ease;
    opacity: 0;
    animation: fadeIn 0.8s ease 2.2s forwards;
  }

  .hero-cta:hover {
    background: rgba(201, 168, 76, 0.08);
    border-color: var(--gold);
    box-shadow: 0 0 30px rgba(201, 168, 76, 0.15);
    color: var(--gold-bright);
  }

  /* --- Scroll Indicator --- */
  .hero-scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    opacity: 0;
    animation: fadeIn 0.8s ease 2.8s forwards;
  }

  .hero-scroll-line {
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, var(--gold), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(0.6); transform-origin: top; }
    50% { opacity: 0.8; transform: scaleY(1); transform-origin: top; }
  }
</style>
