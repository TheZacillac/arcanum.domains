---
---

<section class="architecture" id="architecture">
  <div class="container">
    <h2 class="section-title reveal">Architecture</h2>
    <hr class="section-rule reveal" />
    <p class="section-subtitle reveal">
      Layered by purpose — from raw diagnostics to natural conversation.
    </p>

    <div class="arch-diagram reveal">
      <!-- Layer labels -->
      <div class="arch-layer-labels">
        <span class="arch-layer-label" style="--row: 1;">Interface</span>
        <span class="arch-layer-label" style="--row: 2;">Integration</span>
        <span class="arch-layer-label" style="--row: 3;">Core</span>
      </div>

      <!-- Connections SVG -->
      <svg class="arch-lines" viewBox="0 0 800 460" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
        <!-- Arcanum to Familiar -->
        <line x1="400" y1="56" x2="200" y2="160" class="arch-line" />
        <!-- Arcanum to Tower -->
        <line x1="400" y1="56" x2="400" y2="160" class="arch-line" />
        <!-- Arcanum to Scrolls -->
        <line x1="400" y1="56" x2="600" y2="160" class="arch-line" />
        <!-- Familiar to Tower (uses) -->
        <line x1="200" y1="216" x2="400" y2="216" class="arch-line dashed" />
        <!-- Tower to Seer -->
        <line x1="340" y1="260" x2="260" y2="340" class="arch-line" />
        <!-- Tower to Tome -->
        <line x1="460" y1="260" x2="540" y2="340" class="arch-line" />
        <!-- Scrolls to Tower (bundled) -->
        <line x1="600" y1="216" x2="460" y2="216" class="arch-line dashed" />
        <!-- Familiar to Scrolls (uses) -->
        <line x1="200" y1="200" x2="600" y2="200" class="arch-line dashed thin" />
      </svg>

      <!-- Nodes -->
      <div class="arch-nodes">
        <!-- Top tier: Arcanum -->
        <div class="arch-node arch-arcanum" style="--col: 3; --row: 1;">
          <span class="arch-node-pip" style="--pip-color: var(--gold);"></span>
          <span class="arch-node-name">Arcanum</span>
          <span class="arch-node-desc">Meta-package</span>
        </div>

        <!-- Middle tier: Familiar, Tower, Scrolls -->
        <div class="arch-node" style="--col: 1; --row: 2; --accent: var(--familiar);">
          <span class="arch-node-pip" style="--pip-color: var(--familiar);"></span>
          <span class="arch-node-name">Familiar</span>
          <span class="arch-node-desc">AI Agent</span>
        </div>

        <div class="arch-node" style="--col: 3; --row: 2; --accent: var(--tower);">
          <span class="arch-node-pip" style="--pip-color: var(--tower);"></span>
          <span class="arch-node-name">Tower</span>
          <span class="arch-node-desc">MCP Server · 19 tools</span>
        </div>

        <div class="arch-node" style="--col: 5; --row: 2; --accent: var(--scrolls);">
          <span class="arch-node-pip" style="--pip-color: var(--scrolls);"></span>
          <span class="arch-node-name">Scrolls</span>
          <span class="arch-node-desc">Agent Skills</span>
        </div>

        <!-- Bottom tier: Seer, Tome -->
        <div class="arch-node" style="--col: 2; --row: 3; --accent: var(--seer);">
          <span class="arch-node-pip" style="--pip-color: var(--seer);"></span>
          <span class="arch-node-name">Seer</span>
          <span class="arch-node-desc">Rust core · 13 tools</span>
        </div>

        <div class="arch-node" style="--col: 4; --row: 3; --accent: var(--tome);">
          <span class="arch-node-pip" style="--pip-color: var(--tome);"></span>
          <span class="arch-node-name">Tome</span>
          <span class="arch-node-desc">Rust core · 6 tools</span>
        </div>
      </div>
    </div>

    <!-- Legend -->
    <div class="arch-legend reveal">
      <div class="arch-legend-item">
        <span class="arch-legend-line solid"></span>
        <span>Dependency</span>
      </div>
      <div class="arch-legend-item">
        <span class="arch-legend-line dashed"></span>
        <span>Uses / Bundles</span>
      </div>
    </div>

    <!-- Flow description -->
    <div class="arch-flow reveal">
      <div class="arch-flow-item">
        <span class="arch-flow-num">1</span>
        <p><strong>Seer</strong> and <strong>Tome</strong> form the foundation — Rust performance cores with Python bindings providing raw domain diagnostics and reference data.</p>
      </div>
      <div class="arch-flow-item">
        <span class="arch-flow-num">2</span>
        <p><strong>Tower</strong> consolidates both into a single MCP server, while <strong>Scrolls</strong> provides the contextual knowledge that AI agents need to use them effectively.</p>
      </div>
      <div class="arch-flow-item">
        <span class="arch-flow-num">3</span>
        <p><strong>Familiar</strong> sits at the top — a conversational agent that leverages Tower's tools and Scrolls' knowledge to answer questions in natural language.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .architecture {
    padding: 8rem 2rem;
    background:
      radial-gradient(ellipse 60% 40% at 30% 80%, rgba(42, 22, 80, 0.25), transparent),
      radial-gradient(ellipse 60% 40% at 70% 20%, rgba(30, 16, 64, 0.4), transparent),
      var(--void);
  }

  /* --- Diagram Container --- */
  .arch-diagram {
    position: relative;
    max-width: 800px;
    height: 460px;
    margin: 0 auto 3rem;
  }

  /* --- Layer Labels --- */
  .arch-layer-labels {
    position: absolute;
    left: -1rem;
    top: 0;
    bottom: 0;
    width: 0;
    pointer-events: none;
  }

  .arch-layer-label {
    position: absolute;
    left: -80px;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
    opacity: 0.5;
    white-space: nowrap;
  }

  .arch-layer-label[style*="--row: 1"] { top: 30px; }
  .arch-layer-label[style*="--row: 2"] { top: 190px; }
  .arch-layer-label[style*="--row: 3"] { top: 350px; }

  /* --- SVG Lines --- */
  .arch-lines {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  .arch-line {
    stroke: var(--neon-purple);
    stroke-width: 1;
    opacity: 0.4;
  }

  .arch-line.dashed {
    stroke: var(--neon-pink);
    stroke-dasharray: 6 4;
    opacity: 0.3;
  }

  .arch-line.thin {
    stroke-width: 0.5;
    opacity: 0.2;
  }

  /* --- Nodes --- */
  .arch-nodes {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .arch-node {
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    padding: 0.75rem 1.5rem;
    background: rgba(14, 5, 32, 0.9);
    border: 1px solid var(--border);
    border-radius: 0;
    transition: all 0.4s ease;
    cursor: default;
  }

  .arch-node:hover {
    border-color: var(--accent, var(--neon-purple));
    background: rgba(22, 10, 48, 0.95);
    transform: scale(1.05);
    box-shadow: 0 0 20px color-mix(in srgb, var(--accent, var(--neon-purple)) 25%, transparent);
  }

  /* Position nodes on grid */
  .arch-node[style*="--row: 1"][style*="--col: 3"] {
    top: 12px; left: 50%; transform: translateX(-50%);
  }
  .arch-node[style*="--row: 2"][style*="--col: 1"] {
    top: 172px; left: 12%;
  }
  .arch-node[style*="--row: 2"][style*="--col: 3"] {
    top: 172px; left: 50%; transform: translateX(-50%);
  }
  .arch-node[style*="--row: 2"][style*="--col: 5"] {
    top: 172px; right: 12%;
  }
  .arch-node[style*="--row: 3"][style*="--col: 2"] {
    top: 332px; left: 25%; transform: translateX(-50%);
  }
  .arch-node[style*="--row: 3"][style*="--col: 4"] {
    top: 332px; right: 25%; transform: translateX(50%);
  }

  /* Hover overrides for translated nodes */
  .arch-node[style*="--row: 1"][style*="--col: 3"]:hover,
  .arch-node[style*="--row: 2"][style*="--col: 3"]:hover {
    transform: translateX(-50%) scale(1.05);
  }
  .arch-node[style*="--row: 3"][style*="--col: 2"]:hover {
    transform: translateX(-50%) scale(1.05);
  }
  .arch-node[style*="--row: 3"][style*="--col: 4"]:hover {
    transform: translateX(50%) scale(1.05);
  }

  .arch-node-pip {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--pip-color, var(--neon-cyan));
    box-shadow: 0 0 12px var(--pip-color, var(--neon-cyan)), 0 0 24px color-mix(in srgb, var(--pip-color, var(--neon-cyan)) 50%, transparent);
    margin-bottom: 0.15rem;
  }

  .arch-node-name {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    letter-spacing: 0.08em;
    color: var(--text-bright);
  }

  .arch-node-desc {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    color: var(--text-dim);
    text-transform: uppercase;
  }

  .arch-arcanum {
    border-color: var(--gold-dim);
  }
  .arch-arcanum .arch-node-name {
    color: var(--gold);
    font-family: var(--font-display);
    font-size: 0.85rem;
    letter-spacing: 0.15em;
  }

  /* --- Legend --- */
  .arch-legend {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin-bottom: 4rem;
  }

  .arch-legend-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-dim);
  }

  .arch-legend-line {
    display: block;
    width: 24px;
    height: 1px;
    background: var(--neon-purple);
  }

  .arch-legend-line.dashed {
    background: none;
    border-top: 1px dashed var(--neon-pink);
  }

  /* --- Flow Description --- */
  .arch-flow {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
    max-width: 960px;
    margin: 0 auto;
  }

  .arch-flow-item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .arch-flow-num {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--gold);
    border: 1px solid var(--gold-dim);
    border-radius: 50%;
  }

  .arch-flow-item p {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--text);
  }

  .arch-flow-item strong {
    color: var(--text-bright);
    font-weight: 500;
  }

  /* --- Responsive --- */
  @media (max-width: 720px) {
    .arch-diagram {
      height: auto;
      min-height: 500px;
    }

    .arch-layer-labels {
      display: none;
    }

    .arch-lines {
      display: none;
    }

    .arch-nodes {
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1rem;
      padding: 1rem 0;
    }

    .arch-node {
      position: relative !important;
      top: auto !important;
      left: auto !important;
      right: auto !important;
      transform: none !important;
      width: 80%;
      max-width: 240px;
    }

    .arch-node:hover {
      transform: scale(1.03) !important;
    }

    .arch-flow {
      grid-template-columns: 1fr;
    }
  }
</style>
